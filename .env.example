NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Sell-Safe Buy-Safe"

# ============================================================
# Supabase (Postgres + Auth + Storage)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth Send-SMS hook signing secret. Configure the hook at
# Supabase dashboard → Auth → Hooks → Send SMS Hook →
#   Endpoint: https://<your-domain>/api/auth/sms-hook
#   Secret:   (paste the value Supabase generates here)
SUPABASE_AUTH_HOOK_SECRET=

# Direct Postgres connection — use the Supabase Transaction Pooler URL (port 6543).
# Supabase dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=

# ============================================================
# Moolre (primary PSP — Ghana MoMo + bank transfers)
# ============================================================
# Moolre's own docs call these MOOLRE_API_USER / MOOLRE_API_PUBKEY / MOOLRE_API_KEY /
# MOOLRE_API_VASKEY / MOOLRE_CALLBACK_SECRET. We renamed them here for clarity —
# map your Moolre dashboard credentials to these variable names:
#   MOOLRE_API_USER       → MOOLRE_USERNAME
#   MOOLRE_API_PUBKEY     → MOOLRE_PUBLIC_KEY
#   MOOLRE_API_KEY        → MOOLRE_API_KEY (same)
#   MOOLRE_API_VASKEY     → MOOLRE_SMS_VASKEY
#   MOOLRE_CALLBACK_SECRET → MOOLRE_WEBHOOK_SECRET
MOOLRE_USERNAME=
MOOLRE_PUBLIC_KEY=
MOOLRE_API_KEY=
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_BUSINESS_EMAIL=billing@sbbs.gh
MOOLRE_WEBHOOK_SECRET=
# Optional: Moolre dashboard base URL for deep-links from admin txn detail.
MOOLRE_DASHBOARD_BASE=

# Moolre SMS (shared vendor with payments, distinct X-API-VASKEY credential)
MOOLRE_SMS_VASKEY=
MOOLRE_SMS_SENDER_ID=SBBS
# Optional: set to ASMS07 to simulate unapproved-sender-ID in staging, AIN01
# to simulate auth failure. Leave blank in production.
MOOLRE_SMS_SCENARIO=

# Comma-separated list of phone numbers to ping on critical ops events
# (high-value payouts, name mismatches, webhook signature failures).
OPS_ALERT_PHONES=

# ============================================================
# Paystack (failover; optional once Moolre is live)
# ============================================================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ============================================================
# Hubtel SMS (failover only; optional once Moolre SMS is live)
# ============================================================
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=SBBS

# ============================================================
# Resend (transactional email)
# ============================================================
RESEND_API_KEY=
RESEND_FROM="SBBS <hello@sbbs.gh>"

# ============================================================
# Vercel Cron + daily reconciliation report
# ============================================================
# Any random string — set the same value as the cron Authorization header.
CRON_SECRET=
# Where the daily recon drift report is emailed. Single address for now.
RECON_REPORT_TO=ops@sbbs.gh

# ============================================================
# Platform defaults (seeded into platform_settings — override via /admin/settings)
# ============================================================
PLATFORM_BUYER_FEE_BPS=150
PLATFORM_SELLER_FEE_BPS=150
PLATFORM_RIDER_RELEASE_FEE_PESEWAS=200
PLATFORM_TXN_CAP_PESEWAS=200000
PLATFORM_AUTO_RELEASE_HOURS=72
